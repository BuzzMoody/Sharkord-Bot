<?xml version="1.0" encoding="utf-8"?>
<template>
	<name>sharkord-dark</name>
	<author>SharkordPHP</author>
	<version>1.0.0</version>
	<description>A refined dark theme for SharkordPHP API documentation.</description>
	<extends>default</extends>

